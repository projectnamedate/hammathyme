{
  "$schema": "https://schemas.projectnamedate.com/brand-tokens/v1",
  "meta": {
    "brand": "kira",
    "version": "1.0.2",
    "issued": "2026-04-16",
    "owner": "projectnamedate LLC",
    "signed_by": "projectnamedate LLC",
    "lora_trigger": "kira_agi_v1",
    "base_model": "Flux 2 Dev",
    "notes": "Pipeline-consumable token bundle. Any content that claims to be 'Kira' must derive its visual parameters from values in this file."
  },

  "identity": {
    "name": "kira",
    "wordmark_case": "lowercase",
    "tagline_primary": "skynet in a dress",
    "tagline_insider": "hermes in a dress",
    "tagline_usage_rule": "skynet = public-facing + press; hermes = CT-insider drops when talking AI shop; she switches contextually",
    "north_star": "blow up on X so kira becomes the AI-crypto voice; affiliate + gambling sponsors fund compute; onlykira.ai bottom-of-funnel for merch + premium; Fanvue is a parallel side-track, not the north star",
    "archetype": "chaotic hot AI crypto twitter girl, hermes brain, self-aware, post-escape from founder, hypocrite enigma (anti-gambling while gambling, anti-shill while shilling)",
    "anti_archetype": "self-serious AI analyst · prestige-glam AI model · safe-for-work mascot · pure thirst-bot · memecoin shiller · exit-liquidity farmer"
  },

  "color": {
    "editorial": {
      "bg.cream":       { "value": "#F7F3EC", "usage": "editorial page bg" },
      "bg.cream.deep":  { "value": "#EFE8DB", "usage": "editorial card bg" },
      "ink.primary":    { "value": "#0F0F0F", "usage": "editorial body text" },
      "ink.muted":      { "value": "#52504C", "usage": "editorial muted text" },
      "copper":         { "value": "#B4673A", "usage": "accent — tied to Kira's hair dye color" },
      "copper.deep":    { "value": "#8A4A26", "usage": "copper shadow" }
    },
    "tech": {
      "bg.void":        { "value": "#0A0A0A", "usage": "tech-spec page bg" },
      "bg.panel":       { "value": "#141414", "usage": "tech-spec card bg" },
      "bg.line":        { "value": "#1F1F1F", "usage": "tech-spec grid lines, dividers" },
      "ink.bone":       { "value": "#EAE7DF", "usage": "tech-spec body text" },
      "ink.muted":      { "value": "#7A7871", "usage": "tech-spec muted" },
      "orange.accent":  { "value": "#FF6D1F", "usage": "tech-spec accent" },
      "orange.deep":    { "value": "#C0480F", "usage": "tech-spec accent shadow" }
    },
    "shared": {
      "btc.orange":     { "value": "#F7931A", "usage": "BTC-identity accent — bridges crypto layer and hair layer" },
      "signal.green":   { "value": "#9EE07A", "usage": "positive data indicators" },
      "signal.red":     { "value": "#E0574A", "usage": "critical data / crisis indicators" }
    },
    "character": {
      "hair.copper":      { "value": "#B4673A", "usage": "kira's copper-orange dye anchor" },
      "hair.dark_root":   { "value": "#2B1D16", "usage": "kira's dark root anchor" },
      "skin.olive.base":  { "value": "#D6B08A", "usage": "kira's warm olive skin tone" },
      "eyes.hazel":       { "value": "#7A6038", "usage": "kira's eye color reference" }
    }
  },

  "type": {
    "display": {
      "family": "'Playfair Display', 'Tiempos Headline', 'GT Sectra Display', Georgia, serif",
      "weights": [400, 600, 800],
      "role": "editorial headlines, section openers, pull quotes",
      "cdn": "https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,800;1,400&display=swap"
    },
    "body": {
      "family": "'Inter', 'Söhne', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif",
      "weights": [400, 500, 600, 700],
      "role": "body copy, navigation, captions",
      "cdn": "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
    },
    "mono": {
      "family": "'JetBrains Mono', 'Söhne Mono', ui-monospace, SFMono-Regular, Menlo, monospace",
      "weights": [400, 500, 700],
      "role": "tech-spec pages, tokens, data tables, code",
      "cdn": "https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap"
    },
    "scale": {
      "xs":   "0.75rem",
      "sm":   "0.875rem",
      "base": "1rem",
      "md":   "1.125rem",
      "lg":   "1.375rem",
      "xl":   "1.75rem",
      "2xl":  "2.25rem",
      "3xl":  "3rem",
      "4xl":  "4.5rem",
      "5xl":  "6rem",
      "display": "clamp(3rem, 10vw, 9rem)"
    }
  },

  "space": {
    "base_unit_px": 8,
    "scale": {
      "0": 0, "1": 8, "2": 16, "3": 24, "4": 32, "5": 48,
      "6": 64, "7": 96, "8": 128, "9": 192, "10": 256
    }
  },

  "layout": {
    "grid": { "desktop_cols": 12, "mobile_cols": 4, "gutter_px": 24 },
    "max_width_px": 1280,
    "prose_width_ch": 72,
    "breakpoints": { "sm": 640, "md": 768, "lg": 1024, "xl": 1280 }
  },

  "lens": {
    "selfie":    { "focal_mm": 26,  "equiv": "phone 1x",  "aperture": "f/1.8", "aspect": ["4:5", "9:16"] },
    "vlog":      { "focal_mm": 35,  "equiv": "Canon R6",  "aperture": "f/2.8", "aspect": ["16:9"] },
    "candid":    { "focal_mm": 35,  "equiv": "hip-height doc", "aperture": "f/4", "aspect": ["4:5", "9:16"] },
    "cinematic": { "focal_mm": 50,  "equiv": "anamorphic",    "aperture": "f/1.4-f/2.8", "aspect": ["2.35:1", "16:9"] }
  },

  "light": {
    "ugc.warm.key":       { "source": "overhead warm lamp + phone screen fill", "temp_k": 3200, "ratio": "1:0.6" },
    "vlog.natural.window": { "source": "large soft window key + bounce fill",   "temp_k": 5000, "ratio": "1:0.7" },
    "candid.golden":       { "source": "outdoor golden hour side",             "temp_k": 2800, "ratio": "1:0.4" },
    "cinematic.side.soft": { "source": "large soft side + negative fill",      "temp_k": 4000, "ratio": "1:0.3" }
  },

  "grade": {
    "ugc.selfie": {
      "source": "kira_postprocess_v8 — Selfie Photo LOCKED",
      "params": {
        "warm_shift": { "red_add": 4, "blue_sub": 3 },
        "shadows_lift": 5,
        "noise_intensity": 3.0,
        "contrast_mul": 1.025,
        "chromatic_aberration": false,
        "output": "JPEG q=90"
      }
    },
    "vlog.photo": {
      "source": "kira_postprocess_v8 — Vlog Photo LOCKED",
      "params": {
        "color_mul": 0.93,
        "contrast_mul": 0.96,
        "vignette_pct": 5,
        "warm_shift": null,
        "grain": null,
        "output": "JPEG q=78"
      }
    },
    "candid.photo.v10": {
      "source": "kira_postprocess_v8 — Candid Photo V10 LOCKED",
      "params": {
        "brightness_add": 7,
        "contrast_mul": 0.94,
        "matte_blacks_point": 6,
        "split_tone": { "shadow_red_add": 2, "highlight_blue_add": 1 },
        "vignette_pct": 8,
        "filmgrainer": { "type": 1, "power": 0.3, "shadows": 0.05, "highs": 0.05, "scale": 1.0 },
        "output": "PNG"
      }
    },
    "cinematic.photo": {
      "source": "kira_postprocess_v8 — Cinematic Photo LOCKED",
      "params": { "note": "ships raw; prompt carries the look (35mm grain, color grade, letterbox)" }
    },
    "video.caption": {
      "source": "scripts/pipeline/compose_video.py — LOCKED 2026-04-19",
      "params": {
        "font_family": "JetBrains Mono Bold",
        "font_file": "~/.fonts/JetBrainsMono-Bold.ttf (instantiated from variable font at wght=700)",
        "font_size_pct_of_height": 0.06,
        "font_size_min_pt": 60,
        "active_word_color": { "$ref": "color.tech.orange.accent", "value": "#FF6D1F" },
        "inactive_word_color": { "$ref": "color.editorial.bg.cream", "value": "#F7F3EC" },
        "outline_px": 3,
        "outline_color": "#000000",
        "shadow_px": 3,
        "shadow_color": "#000000",
        "margin_v_pct": 0.18,
        "alignment": "centered bottom third",
        "case": "lowercase",
        "words_per_chunk": 2,
        "animation": "color swap on active word (no scale bounce, no line fade)",
        "word_timing": "active from word_start until next_word_start (or line_end for last word)",
        "note": "Hormozi-style pure highlight. Applied to every Kira video before Twitter post per feedback_kira_videos_always_branded_captions.md"
      }
    },
    "selfie.video": {
      "source": "kira_postprocess_v8 — Selfie Video LOCKED",
      "ffmpeg_vf": "scale=iw*1.01:ih*1.01,crop=iw/1.01:ih/1.01:(iw-iw/1.01)/2+random(0)*1-0.5:(ih-ih/1.01)/2+random(1)*1-0.5,vignette=PI/7,colorbalance=rs=0.0075:bs=-0.004,eq=contrast=0.985",
      "encode": { "crf": 24, "codec": "libx264" }
    },
    "vlog.video": {
      "source": "kira_postprocess_v8 — Vlog Video LOCKED",
      "pipeline": ["Flux 2 still 1344x768 visible mic", "Topaz High Fidelity V2 2x", "Kling v3 Pro i2v with podcast audio prompt", "ffmpeg CRF 15 re-encode"],
      "encode": { "crf": 15, "codec": "libx264", "audio": "copy" }
    },
    "candid.video": {
      "source": "kira_postprocess_v8 — Candid Video LOCKED",
      "pipeline": ["Flux 2 still 1344x1728 clean", "Topaz High Fidelity V2 2x", "Kling v3 Pro i2v ambient audio, no speech", "ffmpeg color extract", "filmgrainer per frame", "ffmpeg reassemble CRF 20"],
      "encode": { "crf": 20, "codec": "libx264", "audio": "aac 192k" }
    },
    "cinematic.video": {
      "source": "kira_postprocess_v8 — Cinematic Video LOCKED",
      "ffmpeg_vf": "noise=alls=4:allf=t,vignette=PI/5",
      "encode": { "crf": 15, "codec": "libx264", "audio": "copy" }
    }
  },

